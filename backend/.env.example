APP_NAME=Cartel
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
LOG_JSON=true
DOCS_ENABLED=true
SCRAPER_TIMEOUT_SECONDS=15
SCRAPER_MAX_RETRIES=3
SCRAPER_RETRY_BACKOFF_SECONDS=1
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126.0.0.0 Safari/537.36
DATA_DIR=../data
BLINKIT_DELIVERY_LOCATION_NAME=New Delhi
BLINKIT_DELIVERY_LATITUDE=28.6139
BLINKIT_DELIVERY_LONGITUDE=77.2090
BLINKIT_GEOLOCATION_ACCURACY=50
BLINKIT_SESSION_STATE_PATH=../data/sessions/blinkit/browser_state.json

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cartel
POSTGRES_USER=cartel
POSTGRES_PASSWORD=change_me

REDIS_URL=redis://localhost:6379/0
